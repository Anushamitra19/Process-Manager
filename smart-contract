#![no_std]

use soroban_sdk::{
    contract, contractimpl, contracttype, symbol_short, vec, Address, Env, Map, String, Symbol,
    Vec,
};

// ─────────────────────────────────────────────────────────────
//  Data Types
// ─────────────────────────────────────────────────────────────

/// Represents a single heartbeat / health snapshot for an indexer process.
#[contracttype]
#[derive(Clone, Debug, Eq, PartialEq)]
pub struct HealthRecord {
    /// Human-readable process name (e.g. "stellar-mainnet-indexer")
    pub process_name: String,
    /// Current status: 0 = online, 1 = stopping, 2 = stopped, 3 = errored
    pub status: u32,
    /// Number of restarts since the process was first launched
    pub restart_count: u32,
    /// Uptime in seconds
    pub uptime_secs: u64,
    /// Memory usage in megabytes
    pub memory_mb: u32,
    /// CPU usage percentage (0-100)
    pub cpu_pct: u32,
    /// Block height lag (0 = fully synced)
    pub block_lag: u32,
    /// Ledger sequence number at time of recording
    pub ledger_seq: u32,
}

/// Persistent key for a crash event record.
#[contracttype]
#[derive(Clone, Debug, Eq, PartialEq)]
pub struct CrashEvent {
    /// Process name that crashed
    pub process_name: String,
    /// Number of crashes within the detection window
    pub crash_count: u32,
    /// Ledger sequence at which the crash loop was detected
    pub detected_at_ledger: u32,
    /// Alert message
    pub alert_message: String,
}

/// Storage keys used by the contract.
#[contracttype]
pub enum DataKey {
    /// The admin address that is authorised to push records
    Admin,
    /// Counter for total health records ever written
    RecordCount,
    /// A single health record, keyed by a sequential u64 ID
    Health(u64),
    /// Latest health snapshot per process name
    LatestHealth(String),
    /// Counter for total crash events
    CrashCount,
    /// A single crash event, keyed by sequential u64 ID
    Crash(u64),
    /// List of all registered process names
    ProcessNames,
}

// ─────────────────────────────────────────────────────────────
//  Contract
// ─────────────────────────────────────────────────────────────

#[contract]
pub struct ProcessHealthRegistry;

#[contractimpl]
impl ProcessHealthRegistry {
    // ───── Initialisation ─────

    /// Initialise the contract with an admin address.
    /// Can only be called once.
    pub fn initialize(env: Env, admin: Address) {
        if env.storage().instance().has(&DataKey::Admin) {
            panic!("already initialised");
        }
        admin.require_auth();
        env.storage().instance().set(&DataKey::Admin, &admin);
        env.storage().instance().set(&DataKey::RecordCount, &0u64);
        env.storage().instance().set(&DataKey::CrashCount, &0u64);

        let empty_names: Vec<String> = vec![&env];
        env.storage()
            .instance()
            .set(&DataKey::ProcessNames, &empty_names);

        env.events()
            .publish((symbol_short!("init"),), admin.clone());
    }

    // ───── Admin helpers ─────

    /// Return the current admin address.
    pub fn get_admin(env: Env) -> Address {
        env.storage()
            .instance()
            .get::<DataKey, Address>(&DataKey::Admin)
            .expect("not initialised")
    }

    /// Transfer admin role to a new address. Requires current admin auth.
    pub fn transfer_admin(env: Env, new_admin: Address) {
        let admin: Address = Self::get_admin(env.clone());
        admin.require_auth();
        new_admin.require_auth();
        env.storage().instance().set(&DataKey::Admin, &new_admin);

        env.events()
            .publish((symbol_short!("adm_xfer"),), new_admin.clone());
    }

    // ───── Write paths ─────

    /// Record a health heartbeat for one process.
    /// Only callable by the admin.
    pub fn record_health(
        env: Env,
        process_name: String,
        status: u32,
        restart_count: u32,
        uptime_secs: u64,
        memory_mb: u32,
        cpu_pct: u32,
        block_lag: u32,
    ) -> u64 {
        let admin: Address = Self::get_admin(env.clone());
        admin.require_auth();

        let ledger_seq = env.ledger().sequence();

        let record = HealthRecord {
            process_name: process_name.clone(),
            status,
            restart_count,
            uptime_secs,
            memory_mb,
            cpu_pct,
            block_lag,
            ledger_seq,
        };

        // Increment global counter
        let mut count: u64 = env
            .storage()
            .instance()
            .get::<DataKey, u64>(&DataKey::RecordCount)
            .unwrap_or(0);
        count += 1;
        env.storage()
            .instance()
            .set(&DataKey::RecordCount, &count);

        // Store the record by sequential ID
        env.storage()
            .persistent()
            .set(&DataKey::Health(count), &record);

        // Upsert latest snapshot
        env.storage()
            .persistent()
            .set(&DataKey::LatestHealth(process_name.clone()), &record);

        // Register the process name if new
        let mut names: Vec<String> = env
            .storage()
            .instance()
            .get::<DataKey, Vec<String>>(&DataKey::ProcessNames)
            .unwrap_or(vec![&env]);

        let mut found = false;
        for i in 0..names.len() {
            if names.get(i).unwrap() == process_name {
                found = true;
                break;
            }
        }
        if !found {
            names.push_back(process_name.clone());
            env.storage()
                .instance()
                .set(&DataKey::ProcessNames, &names);
        }

        env.events()
            .publish((symbol_short!("health"),), record.clone());

        count
    }

    /// Record a crash-loop alert for a process.
    /// Only callable by the admin.
    pub fn record_crash(
        env: Env,
        process_name: String,
        crash_count: u32,
        alert_message: String,
    ) -> u64 {
        let admin: Address = Self::get_admin(env.clone());
        admin.require_auth();

        let ledger_seq = env.ledger().sequence();

        let event = CrashEvent {
            process_name,
            crash_count,
            detected_at_ledger: ledger_seq,
            alert_message,
        };

        let mut count: u64 = env
            .storage()
            .instance()
            .get::<DataKey, u64>(&DataKey::CrashCount)
            .unwrap_or(0);
        count += 1;
        env.storage()
            .instance()
            .set(&DataKey::CrashCount, &count);

        env.storage()
            .persistent()
            .set(&DataKey::Crash(count), &event);

        env.events()
            .publish((symbol_short!("crash"),), event.clone());

        count
    }

    // ───── Read paths ─────

    /// Get total number of health records written.
    pub fn get_record_count(env: Env) -> u64 {
        env.storage()
            .instance()
            .get::<DataKey, u64>(&DataKey::RecordCount)
            .unwrap_or(0)
    }

    /// Get a specific health record by its sequential ID.
    pub fn get_health(env: Env, record_id: u64) -> HealthRecord {
        env.storage()
            .persistent()
            .get::<DataKey, HealthRecord>(&DataKey::Health(record_id))
            .expect("record not found")
    }

    /// Get the latest health snapshot for a given process name.
    pub fn get_latest_health(env: Env, process_name: String) -> HealthRecord {
        env.storage()
            .persistent()
            .get::<DataKey, HealthRecord>(&DataKey::LatestHealth(process_name))
            .expect("no snapshot for process")
    }

    /// Get all registered process names.
    pub fn get_process_names(env: Env) -> Vec<String> {
        env.storage()
            .instance()
            .get::<DataKey, Vec<String>>(&DataKey::ProcessNames)
            .unwrap_or(vec![&env])
    }

    /// Get total crash events recorded.
    pub fn get_crash_count(env: Env) -> u64 {
        env.storage()
            .instance()
            .get::<DataKey, u64>(&DataKey::CrashCount)
            .unwrap_or(0)
    }

    /// Get a specific crash event by ID.
    pub fn get_crash(env: Env, crash_id: u64) -> CrashEvent {
        env.storage()
            .persistent()
            .get::<DataKey, CrashEvent>(&DataKey::Crash(crash_id))
            .expect("crash event not found")
    }
}

// ─────────────────────────────────────────────────────────────
//  Tests
// ─────────────────────────────────────────────────────────────

#[cfg(test)]
mod tests {
    use super::*;
    use soroban_sdk::{testutils::Address as _, Env, String};

    #[test]
    fn test_initialize_and_admin() {
        let env = Env::default();
        env.mock_all_auths();
        let contract_id = env.register(ProcessHealthRegistry, ());
        let client = ProcessHealthRegistryClient::new(&env, &contract_id);

        let admin = Address::generate(&env);
        client.initialize(&admin);

        assert_eq!(client.get_admin(), admin);
        assert_eq!(client.get_record_count(), 0);
        assert_eq!(client.get_crash_count(), 0);
    }

    #[test]
    fn test_record_health() {
        let env = Env::default();
        env.mock_all_auths();
        let contract_id = env.register(ProcessHealthRegistry, ());
        let client = ProcessHealthRegistryClient::new(&env, &contract_id);

        let admin = Address::generate(&env);
        client.initialize(&admin);

        let name = String::from_str(&env, "stellar-mainnet-indexer");
        let record_id = client.record_health(&name, &0, &3, &86400, &128, &25, &0);

        assert_eq!(record_id, 1);
        assert_eq!(client.get_record_count(), 1);

        let record = client.get_health(&1);
        assert_eq!(record.process_name, name);
        assert_eq!(record.status, 0);
        assert_eq!(record.restart_count, 3);
        assert_eq!(record.memory_mb, 128);
        assert_eq!(record.cpu_pct, 25);
        assert_eq!(record.block_lag, 0);
    }

    #[test]
    fn test_latest_health_snapshot() {
        let env = Env::default();
        env.mock_all_auths();
        let contract_id = env.register(ProcessHealthRegistry, ());
        let client = ProcessHealthRegistryClient::new(&env, &contract_id);

        let admin = Address::generate(&env);
        client.initialize(&admin);

        let name = String::from_str(&env, "stellar-testnet-indexer");

        // First heartbeat
        client.record_health(&name, &0, &0, &100, &50, &10, &5);
        // Second heartbeat — should overwrite latest
        client.record_health(&name, &0, &0, &200, &55, &12, &0);

        let latest = client.get_latest_health(&name);
        assert_eq!(latest.uptime_secs, 200);
        assert_eq!(latest.memory_mb, 55);
        assert_eq!(latest.block_lag, 0);

        assert_eq!(client.get_record_count(), 2);
    }

    #[test]
    fn test_record_crash() {
        let env = Env::default();
        env.mock_all_auths();
        let contract_id = env.register(ProcessHealthRegistry, ());
        let client = ProcessHealthRegistryClient::new(&env, &contract_id);

        let admin = Address::generate(&env);
        client.initialize(&admin);

        let name = String::from_str(&env, "stellar-mainnet-indexer");
        let msg = String::from_str(&env, "Crash loop detected: 3 restarts in 60s");

        let crash_id = client.record_crash(&name, &3, &msg);
        assert_eq!(crash_id, 1);
        assert_eq!(client.get_crash_count(), 1);

        let crash = client.get_crash(&1);
        assert_eq!(crash.process_name, name);
        assert_eq!(crash.crash_count, 3);
    }

    #[test]
    fn test_process_names_registry() {
        let env = Env::default();
        env.mock_all_auths();
        let contract_id = env.register(ProcessHealthRegistry, ());
        let client = ProcessHealthRegistryClient::new(&env, &contract_id);

        let admin = Address::generate(&env);
        client.initialize(&admin);

        let n1 = String::from_str(&env, "stellar-mainnet-indexer");
        let n2 = String::from_str(&env, "stellar-testnet-indexer");

        client.record_health(&n1, &0, &0, &100, &50, &10, &0);
        client.record_health(&n2, &0, &0, &200, &60, &15, &1);
        // Duplicate — should NOT add again
        client.record_health(&n1, &0, &1, &300, &52, &11, &0);

        let names = client.get_process_names();
        assert_eq!(names.len(), 2);
    }

    #[test]
    fn test_transfer_admin() {
        let env = Env::default();
        env.mock_all_auths();
        let contract_id = env.register(ProcessHealthRegistry, ());
        let client = ProcessHealthRegistryClient::new(&env, &contract_id);

        let admin = Address::generate(&env);
        let new_admin = Address::generate(&env);

        client.initialize(&admin);
        client.transfer_admin(&new_admin);

        assert_eq!(client.get_admin(), new_admin);
    }
}